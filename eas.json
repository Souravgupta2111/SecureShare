{
    "cli": {
        "version": ">= 10.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "environment": "development",
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            },
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NODE_ENV": "development"
            }
        },
        "preview": {
            "environment": "preview",
            "distribution": "internal",
            "ios": {
                "simulator": false
            },
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NODE_ENV": "production"
            }
        },
        "production": {
            "environment": "production",
            "distribution": "store",
            "autoIncrement": true,
            "ios": {
                "resourceClass": "m-medium"
            },
            "android": {
                "buildType": "app-bundle"
            },
            "env": {
                "NODE_ENV": "production"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./path-to-service-account.json",
                "track": "internal"
            }
        }
    }
}