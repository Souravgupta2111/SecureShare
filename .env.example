# SecureShare environment variables
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# NOTE: Only EXPO_PUBLIC_* variables are embedded in the app bundle and readable
# on the client. Do NOT put secrets you want kept private in EXPO_PUBLIC_* vars.
# For production builds, set these as EAS secrets:
#   eas secret:create --name EXPO_PUBLIC_SUPABASE_URL --value "https://xxxx.supabase.co"

# --- Supabase (required) ---
# Project URL, e.g. https://abcdefghijklmno.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose on the client; protected by Row Level Security)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase service role (server/CI only — NEVER ship in the app) ---
# Used only for migrations / admin scripts. Keep this out of EXPO_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
